---
import Footer from "../components/Footer.astro";
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Personal Portfolio and CV" />
    <meta name="viewport" content="width=device-width" />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL}favicon.svg`}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
        rel="stylesheet"
      />
    </noscript>
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>document.documentElement.classList.add('js-ready');</script>
    <style is:global>
      :root {
        --ease-out-quart: cubic-bezier(0.25, 1, 0.5, 1);
        --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
      }

      @keyframes fade-up-in {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      @keyframes scale-up-in {
        from { opacity: 0; transform: scale(0.88); }
        to   { opacity: 1; transform: scale(1); }
      }

      @keyframes slide-left-in {
        from { opacity: 0; transform: translateX(-14px); }
        to   { opacity: 1; transform: translateX(0); }
      }

      /* Page-load stagger — fires via CSS, no JS needed */
      [data-stagger] {
        animation: fade-up-in 480ms var(--ease-out-quart) both;
        animation-delay: calc(var(--i, 0) * 75ms + 80ms);
      }

      /* Scroll reveals — only engaged once JS marks body ready */
      .js-ready [data-reveal] {
        opacity: 0;
      }
      .js-ready [data-reveal].is-visible {
        animation: fade-up-in 480ms var(--ease-out-quart) forwards;
      }

      .js-ready [data-reveal-left] {
        opacity: 0;
      }
      .js-ready [data-reveal-left].is-visible {
        animation: slide-left-in 420ms var(--ease-out-quart) forwards;
      }

      .js-ready [data-reveal-stagger] {
        opacity: 0;
      }
      .js-ready [data-reveal-stagger].is-visible {
        animation: fade-up-in 400ms var(--ease-out-quart) both;
        animation-delay: calc(var(--i, 0) * 60ms);
      }

      @media (prefers-reduced-motion: reduce) {
        [data-stagger] {
          animation: none !important;
        }
        .js-ready [data-reveal],
        .js-ready [data-reveal-left],
        .js-ready [data-reveal-stagger] {
          opacity: 1 !important;
        }
        .js-ready [data-reveal].is-visible,
        .js-ready [data-reveal-left].is-visible,
        .js-ready [data-reveal-stagger].is-visible {
          animation: none !important;
        }
      }
    </style>
  </head>
  <body
    class="bg-slate-50 text-slate-900 font-sans antialiased selection:bg-blue-100 selection:text-blue-900"
  >
    <slot />
    <Footer />
    <script is:inline>
      (function () {
        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.08, rootMargin: '0px 0px -28px 0px' });
        document.querySelectorAll('[data-reveal],[data-reveal-left],[data-reveal-stagger]').forEach(function (el) {
          observer.observe(el);
        });
      })();
    </script>
  </body>
</html>
